# Backend Configuration
API_PORT=8081
API_HOST=0.0.0.0
# APIベースパス(絶対URL生成用、外部システム統合対応)
API_BASE_PATH=/ai/api

# Frontend Configuration
# 開発時は空（Viteプロキシを使用）、本番時は実際のAPIサーバーURL
VITE_API_BASE=

# OCI Configuration
OCI_CONFIG_FILE=/root/.oci/config
OCI_PROFILE=DEFAULT
OCI_KEY_FILE=/root/.oci/oci_api_key.pem
OCI_REGION=us-chicago-1
OCI_COMPARTMENT_OCID=ocid1.compartment.oc1..aaaaaa
OCI_REGION_DEPLOY=ap-osaka-1
OCI_BUCKET=semantic-doc-search
OCI_NAMESPACE=

# OCI Enterprise AI Configuration
OCI_ENTERPRISE_AI_BASE_URL=https://inference.generativeai.us-chicago-1.oci.oraclecloud.com/openai/v1
OCI_ENTERPRISE_AI_PROJECT=ocid1.generativeaiproject.oc1.us-chicago-1.aaaaaa
OCI_ENTERPRISE_AI_API_KEY=
OCI_ENTERPRISE_AI_MODEL=xai.grok-4.3
ENTERPRISE_AI_VLM_CONNECT_TIMEOUT_SECONDS=30
ENTERPRISE_AI_VLM_REQUEST_TIMEOUT_SECONDS=600
ENTERPRISE_AI_VLM_MAX_RETRIES=2
PIPELINE_TRANSIENT_STEP_MAX_ATTEMPTS=2
PIPELINE_TRANSIENT_RETRY_DELAY_SECONDS=5
# 全Jobを合算して同時に処理するファイル数。変更後はバックエンドを再起動する。
PIPELINE_MAX_CONCURRENT_FILES=3
# 以下は全体上限を超えない範囲で適用する個別上限。
# 永続Jobを同時に処理する上限。大きいJobが後続Jobを独占しないための設定。
PIPELINE_MAX_CONCURRENT_JOBS=3
# 1 Job内で同時に進めるファイル数。同一ファイル内の段階は常に直列。
PIPELINE_MAX_CONCURRENT_FILES_PER_JOB=3
# ページ単位VLM抽出を行うファイルの同時実行上限。
PIPELINE_MAX_CONCURRENT_VLM_STEPS=3

# Oracle Database Configuration
ORACLE_CLIENT_LIB_DIR=/u01/aipoc/instantclient_23_26
ORACLE_26AI_CONNECTION_STRING=admin/password@dsn
ADB_OCID=ocid1.autonomousdatabase.oc1..aaaaaa
# 未指定時はADB_OCIDから自動判定します。
ADB_REGION=

# Upload / Access / Token Configuration
MAX_FILE_SIZE=200000000
# 最大オブジェクト取得件数（メモリ保護）
MAX_OBJECTS_FETCH=10000
# 許可されるファイル拡張子（カンマ区切り）
ALLOWED_EXTENSIONS=pdf,xlsx,xls,docx,doc,pptx,ppt,png,jpg,jpeg,txt,md
# 外部APIキー設定（カンマ区切りで複数指定可能。空の場合は無効）
EXTERNAL_API_KEYS=
# 検索結果URLの短寿命トークン有効期限（秒）
TEMP_TOKEN_TIMEOUT_SECONDS=300

# API Retry / Concurrency Configuration
OCI_API_MAX_RETRIES=5
OCI_API_BASE_DELAY=1.0
OCI_API_MAX_DELAY=60.0
OCI_API_JITTER=0.1
OBJECT_STORAGE_CONNECT_TIMEOUT_SECONDS=10
OBJECT_STORAGE_TRANSFER_TIMEOUT_SECONDS=300
OBJECT_STORAGE_MULTIPART_THRESHOLD_BYTES=10485760
OBJECT_STORAGE_MULTIPART_PART_SIZE_BYTES=10485760
OBJECT_STORAGE_MULTIPART_WORKERS=3
EMBEDDING_API_MAX_RETRIES=5
EMBEDDING_API_BASE_DELAY=1.5
EMBEDDING_API_MAX_DELAY=120.0
EMBEDDING_API_JITTER=0.2
GENAI_API_MAX_RETRIES=5
GENAI_API_BASE_DELAY=2.0
GENAI_API_MAX_DELAY=180.0
GENAI_API_JITTER=0.15
# 並列処理のAPI同時呼び出し制限
API_CONCURRENT_LIMIT=3
API_MAX_RETRIES=5
API_RETRY_BASE_DELAY=1.0

# Embedding Configuration
OCI_COHERE_EMBED_MODEL=cohere.embed-v4.0
OCI_EMBEDDING_INPUT_TYPE=IMAGE
OCI_EMBEDDING_TRUNCATE=END
OCI_EMBEDDING_MAX_RETRIES=3
OCI_EMBEDDING_RETRY_DELAY=1
OCI_EMBEDDING_DIMENSIONS=1536

# Retrieval / Oracle Text / VLM Configuration
# Retrieval query expansion
RAG_QUERY_EXPANSION_ENABLED=true
RAG_QUERY_EXPANSION_LLM_ENABLED=false
RAG_QUERY_EXPANSION_MAX_VARIANTS=3
# Oracle Text 検索キーワード最大数
ORACLE_TEXT_MAX_TERMS=20
# 問い合わせ整理
VLM_QUERY_ENABLED=true
VLM_VERIFY_ENABLED=true
VLM_QUERY_PROMPT=Generate up to three concise search variants that preserve the user's meaning. Return JSON with query_variants and intent.
VLM_VERIFY_PROMPT=Verify whether the candidate image satisfies the user's request. Return JSON with verified, confidence, evidence, and failed_constraints.
# Retrieval channel weights
RETRIEVAL_WEIGHT_ORACLE_TEXT=1.0
RETRIEVAL_WEIGHT_TEXT_VECTOR=1.0
RETRIEVAL_WEIGHT_VISUAL_VECTOR=1.0
RETRIEVAL_WEIGHT_VLM_TEXT=1.0
RETRIEVAL_WEIGHT_VLM_VECTOR=1.0

# OCR / MinerU Configuration
OCR_ENABLED=false
DOTS_MOCR_ENABLED=true
DOTS_MOCR_API_HOST=
DOTS_MOCR_MODEL=rednote-hilab/dots.mocr
DOTS_MOCR_API_KEY=
DOTS_MOCR_DPI=200
DOTS_MOCR_PDF_WORKERS=4
OCR_API_HOST=
OCR_MODEL=glm-ocr
OCR_DPI=200
OCR_PDF_WORKERS=1
GLM_OCR_DPI=200
UNLIMITED_OCR_ENABLED=true
UNLIMITED_OCR_API_HOST=
UNLIMITED_OCR_MODEL=/models/Unlimited-OCR
UNLIMITED_OCR_API_KEY=
UNLIMITED_OCR_DPI=300
UNLIMITED_OCR_PDF_WORKERS=1
MINERU_ENABLED=false
MINERU_API_HOST=
MINERU_API_TIMEOUT_SECONDS=1800

# Storage Configuration
STORAGE_PATH=./storage
UPLOAD_PATH=./storage/uploads

# Runtime / UI Feature Toggles
# External IP address for application access (auto-detected by init_script.sh)
EXTERNAL_IP=127.0.0.1
# Enable debug mode (true for development, false for production)
DEBUG=false
# AIアシスタントの表示制御
SHOW_AI_ASSISTANT=true
# 検索タブの表示制御
SHOW_SEARCH_TAB=true
