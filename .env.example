# Backend Configuration
API_PORT=8081
API_HOST=0.0.0.0

# Frontend Configuration
VITE_API_BASE=http://localhost:8081

# OCI Configuration
OCI_CONFIG_FILE=/root/.oci/config
OCI_PROFILE=DEFAULT
OCI_KEY_FILE=/root/.oci/oci_api_key.pem
OCI_REGION=us-chicago-1
OCI_COMPARTMENT_OCID=ocid1.compartment.oc1..
OCI_REGION_DEPLOY=ap-osaka-1
OCI_BUCKET=semantic-doc-search
OCI_NAMESPACE=

# OCI Enterprise AI Configuration
OCI_ENTERPRISE_AI_BASE_URL='https://inference.generativeai.us-chicago-1.oci.oraclecloud.com/openai/v1'
OCI_ENTERPRISE_AI_PROJECT='ocid1.generativeaiproject.oc1.us-chicago-1.aaaaaa'
OCI_ENTERPRISE_AI_API_KEY='sk-aaaaaa'
OCI_ENTERPRISE_AI_MODEL='xai.grok-4.3'

# Oracle Database Configuration
ORACLE_CLIENT_LIB_DIR=/u01/aipoc/instantclient_23_26
# TNS_ADMIN will be automatically set to ORACLE_CLIENT_LIB_DIR/network/admin
# Wallet files should be placed in ORACLE_CLIENT_LIB_DIR/network/admin
ORACLE_26AI_CONNECTION_STRING=admin/password@dsn
ADB_OCID=ocid1.autonomousdatabase.oc1..

# Upload Configuration
MAX_FILE_SIZE=200000000

# Performance Configuration
# 最大オブジェクト取得件数（メモリ保護）
MAX_OBJECTS_FETCH=10000

# 許可されるファイル拡張子（カンマ区切り）
# PDF: 文書, XLSX/XLS: Excel文書, DOCX/DOC: Word文書, PPT/PPTX: プレゼンテーション, PNG/JPG/JPEG: 画像, TXT/MD: テキスト
ALLOWED_EXTENSIONS=pdf,xlsx,xls,docx,doc,pptx,ppt,png,jpg,jpeg,txt,md

# 外部APIキー設定（カンマ区切りで複数指定可能）
# 例: EXTERNAL_API_KEYS=your-api-key-1,your-api-key-2
# 空の場合は外部API認証は無効化されます
EXTERNAL_API_KEYS=

# 一時トークン有効期限（秒）
# 検索結果のURLに付与される短寿命トークンの有効期限
# デフォルト: 300（5分）
TEMP_TOKEN_TIMEOUT_SECONDS=300

# ========================================
# OCI API レート制限対応設定
# ========================================

# 一般的なOCI API設定
OCI_API_MAX_RETRIES=5
OCI_API_BASE_DELAY=1.0
OCI_API_MAX_DELAY=60.0
OCI_API_JITTER=0.1

# Embedding API専用設定
EMBEDDING_API_MAX_RETRIES=5
EMBEDDING_API_BASE_DELAY=1.5
EMBEDDING_API_MAX_DELAY=120.0
EMBEDDING_API_JITTER=0.2

# Generative AI API専用設定
GENAI_API_MAX_RETRIES=5
GENAI_API_BASE_DELAY=2.0
GENAI_API_MAX_DELAY=180.0
GENAI_API_JITTER=0.15

# 並列処理のAPI同時呼び出し制限
API_CONCURRENT_LIMIT=3
API_MAX_RETRIES=5
API_RETRY_BASE_DELAY=1.0

# ========================================
# Oracle Generative AI設定
# ========================================
OCI_COHERE_EMBED_MODEL=cohere.embed-v4.0
OCI_EMBEDDING_INPUT_TYPE=IMAGE
OCI_EMBEDDING_TRUNCATE=END
OCI_EMBEDDING_MAX_RETRIES=3
OCI_EMBEDDING_RETRY_DELAY=1
OCI_EMBEDDING_DIMENSIONS=1536

# Storage Configuration
STORAGE_PATH=./storage
UPLOAD_PATH=./storage/uploads

# Application Configuration
# EXTERNAL_IP: External IP address for application access (auto-detected by init_script.sh)
# This will be automatically set by init_script.sh
# Note: With nginx reverse proxy, CORS is not an issue (same-origin)
EXTERNAL_IP=127.0.0.1

# DEBUG: Enable debug mode (true for development, false for production)
# - true: Authentication bypassed, detailed error messages
# - false: Authentication required, minimal error messages
# This will be automatically set by init_script.sh
DEBUG=false

# UI Feature Toggles
# SHOW_AI_ASSISTANT: AIアシスタントの表示制御 (true: 表示, false: 非表示)
SHOW_AI_ASSISTANT=true

# SHOW_SEARCH_TAB: 🔍 検索タブの表示制御 (true: 表示, false: 非表示)
SHOW_SEARCH_TAB=true
